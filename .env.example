DEBUG=True
SECRET_KEY=change-me-for-your-mac-mini
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://localhost:7500,http://127.0.0.1:7500
DATABASE_URL=postgres://nintendowatch:nintendowatch@db:5432/nintendowatch
TIME_ZONE=Asia/Seoul

NOTIFICATIONS_ENABLED=false
NOTIFICATION_MIN_IMPORTANCE=80
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=
DISCORD_WEBHOOK_URL=

COLLECTOR_TIMEOUT_SECONDS=10
BACKUP_DIR=/Users/sg_mac/gamenews/backups/postgres

# Korean summaries use local rules by default. Set SUMMARY_PROVIDER=auto or openai
# and OPENAI_API_KEY only when you want LLM-generated summaries.
SUMMARY_PROVIDER=rules
OPENAI_API_KEY=
SUMMARY_OPENAI_MODEL=gpt-5-mini
SUMMARY_TIMEOUT_SECONDS=20
SUMMARY_MAX_SOURCE_CHARS=3000
