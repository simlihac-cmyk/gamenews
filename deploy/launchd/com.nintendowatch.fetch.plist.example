<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.nintendowatch.fetch</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd /Users/sg_mac/gamenews &amp;&amp; ./scripts/macmini_fetch.sh</string>
  </array>
  <key>StartInterval</key>
  <integer>1800</integer>
  <key>StandardOutPath</key>
  <string>/tmp/nintendowatch-fetch.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/nintendowatch-fetch.err</string>
</dict>
</plist>
